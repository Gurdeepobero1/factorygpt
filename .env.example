# ── Required ──────────────────────────────────────────────────────────────────
SARVAM_API_KEY=your_sarvam_key_here

# ── Optional: better AI quality (auto-fallback uses whichever keys are set) ───
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here
# LLM_PROVIDER=sarvam   # or anthropic / openai

# ── Optional: API auth (leave blank for open / dev access) ────────────────────
FACTORYGPT_API_KEY=

# ── Optional: restrict CORS to your deployed frontend domain ──────────────────
# ALLOWED_ORIGINS=https://yourapp.vercel.app

# ── Edge Vision only ──────────────────────────────────────────────────────────
# CLOUD_WS_URL=wss://your-render-url.onrender.com/ws/iot
# STREAM_FPS=10
# JPEG_QUALITY=72

# ── Cloud backend only ────────────────────────────────────────────────────────
# DB_PATH=factorygpt.db
